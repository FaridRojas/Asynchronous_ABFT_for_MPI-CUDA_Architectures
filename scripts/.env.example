# =====================================================================
# Example local environment file for the SC3 deploy script.
# Copy to scripts/.env.local (which is gitignored) and fill in:
#
#   cp scripts/.env.example scripts/.env.local
#   chmod 600 scripts/.env.local
#
# Then scripts/deploy_and_run.sh will source it automatically.
# Do NOT commit scripts/.env.local.
# =====================================================================

# SSH user on the cluster.
SC3_USER=fcrojasv01

# Remote host.
SC3_HOST=toctoc.sc3.uis.edu.co

# Project root on the cluster (must already exist or be creatable).
SC3_REMOTE_ROOT=/scratch/CAGE/fcrojasv

# Cluster password — ONLY if you don't have SSH key auth set up.
# Leave blank to fall back to ssh-key / interactive prompt.
# Requires `sshpass` installed locally.
SC3_PASS=
